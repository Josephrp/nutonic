# Copy to `server/.env` and adjust. Loaded automatically by pydantic-settings
# (real process environment variables override these values).

# Full manifest slices for local clients / fixtures (locations + ai_guesses).
# Default server behavior redacts these for spoiler hygiene.
NUTONIC_EXPOSE_MANIFEST_ROUND_TRUTH=true

# Allow POST /api/v1/community/leaderboard (idempotent writes) in local dev.
FEATURE_COMMUNITY_LB_POST=true

# Optional: guess telemetry endpoint (see server README).
# FEATURE_GUESSES_RECORD=true

# Browser dev (Kotlin/JS or web shell). Comma-separated origins.
# CORS_ORIGINS=http://localhost:8080

# Override dev JWT secret for shared lab hosts (min strong secret in prod).
# JWT_SECRET=your-long-random-secret
