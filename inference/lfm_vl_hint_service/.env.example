# Copy to .env and adjust. See README.md for backend matrix.

# stub | transformers | openai_compatible (aliases: openai, vllm, sglang)
LFM_VL_BACKEND=stub

# Hugging Face model id (transformers + OpenAI-compatible default)
LFM_VL_MODEL_ID=LiquidAI/LFM2.5-VL-450M

# --- transformers in-process (Liquid official HF path) ---
# LFM_VL_TORCH_DTYPE=bfloat16
# LFM_VL_MAX_NEW_TOKENS=256
# LFM_VL_EAGER_LOAD=1

# --- OpenAI-compatible server (vLLM / SGLang per Liquid deployment docs) ---
# LFM_OPENAI_BASE_URL=http://127.0.0.1:8000/v1
# LFM_OPENAI_API_KEY=dummy
# LFM_OPENAI_MODEL=LiquidAI/LFM2.5-VL-450M

# --- Gradio + Hugging Face ZeroGPU (install pip extras: .[serve,model]) ---
# LFM_VL_MOUNT_GRADIO=1
# LFM_VL_ZERO_GPU_DURATION=180
# Place weights on cuda during HF CUDA emulation (ZeroGPU / Docker Space README)
# LFM_VL_FORCE_MODEL_CUDA=1
# Warm transformers weights at process start (outside @spaces.GPU)
# LFM_VL_EAGER_LOAD=1
