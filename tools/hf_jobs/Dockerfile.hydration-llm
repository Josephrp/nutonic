# CPU-only image for narrative / LLM sidecar batch (no torch). Build from repo root:
#   docker build -f tools/hf_jobs/Dockerfile.hydration-llm -t YOUR_DOCKERHUB/nutonic-hydration-llm:TAG .

FROM python:3.12-slim-bookworm

WORKDIR /workspace

RUN pip install --no-cache-dir "huggingface_hub>=0.30.0" "python-dotenv>=1.0.0" "pyyaml>=6.0.0,<7" "pydantic>=2.0.0,<3" "httpx>=0.27.0,<1"

COPY data/scripts/catalog_import_poi.py /workspace/data/scripts/catalog_import_poi.py
COPY data/scripts/narrative_llm_batch.py /workspace/data/scripts/narrative_llm_batch.py
RUN mkdir -p /workspace/prompts/llm
COPY tools/hf_jobs/entrypoint_hf_hydration.py /workspace/tools/hf_jobs/entrypoint_hf_hydration.py
# Sibling module imported by the entrypoint (``sys.path`` = ``.../hf_jobs``).
COPY tools/hf_jobs/hf_output_dataset.py /workspace/tools/hf_jobs/hf_output_dataset.py

# narrative_llm_batch imports REPO_ROOT parents[2] — keep minimal tree so parents match.
ENV PYTHONPATH=/workspace
ENV NUTONIC_NO_DOTENV=1

ENTRYPOINT ["python", "/workspace/tools/hf_jobs/entrypoint_hf_hydration.py"]
