{
  "java.configuration.updateBuildConfiguration": "automatic",
  "java.import.gradle.enabled": true,
  "java.import.gradle.wrapper.enabled": true,
  "files.exclude": {
    "**/.gradle": true,
    "**/build": false
  },
  "search.exclude": {
    "**/nutonic/**/build": true,
    "**/.gradle": true
  },
  "kotlin.debugAdapter.enabled": true,
  "[kotlin]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": true
  }
}
