# GPU hydration image: Street View pano + LFM-VL + data/scripts pipeline.
# Build from repo root:
#   docker build -f tools/hf_jobs/Dockerfile.hydration -t YOUR_DOCKERHUB/nutonic-hydration-sv-lfm:TAG .
#
# Requires secrets at run time: GOOGLE_MAPS_API_KEY, MAPBOX_ACCESS_TOKEN, HF_TOKEN (write-capable).

FROM pytorch/pytorch:2.5.1-cuda12.1-cudnn9-runtime

ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update \
    && apt-get install -y --no-install-recommends git \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

COPY data/scripts/requirements.txt /tmp/data-scripts-requirements.txt
RUN pip install --no-cache-dir -r /tmp/data-scripts-requirements.txt \
    && pip install --no-cache-dir "httpx>=0.27.0,<1" "uvicorn[standard]>=0.32.0,<1" "huggingface_hub>=0.30.0" "python-dotenv>=1.0.0"

COPY inference/streetview_pano_service /workspace/inference/streetview_pano_service
COPY inference/lfm_vl_hint_service /workspace/inference/lfm_vl_hint_service
COPY data/scripts /workspace/data/scripts
COPY tools /workspace/tools
# Repo may not ship a root ``prompts/`` tree yet; narrative job uses ``Dockerfile.hydration-llm``.
RUN mkdir -p /workspace/prompts/llm

RUN pip install --no-cache-dir -e /workspace/inference/streetview_pano_service \
    && pip install --no-cache-dir -e "/workspace/inference/lfm_vl_hint_service[model]"

ENV PYTHONPATH=/workspace
ENV NUTONIC_NO_DOTENV=1

ENTRYPOINT ["python", "/workspace/tools/hf_jobs/entrypoint_hf_hydration.py"]
